{
  "$comment": "Personal form aligned with fe-sub-app v2-form-config personalInformationDocument; formKey personal-information.",
  "templateId": "personal-information-default",
  "moduleKey": "employee-management",
  "formKey": "personal-information",
  "name": "Personal information",
  "version": 1,
  "status": "ACTIVE",
  "sourceSchemaVersion": "employee_schema_v2_4",
  "updatedAt": "2026-03-24T12:30:00.000Z",
  "layoutConstraints": { "maxFieldsPerRow": 2 },
  "sections": [
    {
      "key": "personal",
      "title": "Personal information",
      "rows": [
        { "key": "rowPhoneEmail", "fields": ["persPersonalPhone", "persPersonalEmail"] },
        { "key": "rowMaritalNationality", "fields": ["persMaritalStatus", "persNationality"] },
        { "key": "rowIdDates", "fields": ["persNationalId", "persEthnicity"] },
        { "key": "rowDates", "fields": ["persIssuedDate", "persExpiryDate"] },
        { "key": "rowIssueSocial", "fields": ["persIssueBy", "persSocialInsurance"] }
      ]
    }
  ],
  "fields": {
    "persPersonalPhone": {
      "kind": "system",
      "visible": true,
      "formBinding": "personalNumber",
      "ui": {
        "variant": "phone",
        "label": "Personal Number",
        "placeholder": "Enter personal phone number",
        "translations": {
          "vi-VN": {
            "label": "Số điện thoại cá nhân",
            "placeholder": "Nhập số điện thoại cá nhân"
          }
        }
      }
    },
    "persPersonalEmail": {
      "kind": "system",
      "visible": true,
      "formBinding": "personalEmail",
      "ui": {
        "variant": "input",
        "type": "email",
        "label": "Personal Email",
        "placeholder": "e.g. personal@example.com",
        "translations": {
          "vi-VN": {
            "label": "Email cá nhân",
            "placeholder": "Ví dụ: ca_nhan@example.com"
          }
        }
      }
    },
    "persMaritalStatus": {
      "kind": "system",
      "visible": true,
      "formBinding": "maritalStatus",
      "ui": {
        "variant": "select",
        "label": "Marital Status",
        "placeholder": "Select marital status",
        "options": [
          { "id": "opt-s", "label": "Single", "value": "Single" },
          { "id": "opt-m", "label": "Married", "value": "Married" },
          { "id": "opt-r", "label": "Rather not mention", "value": "Rather not mention" }
        ],
        "translations": {
          "vi-VN": {
            "label": "Tình trạng hôn nhân",
            "placeholder": "Chọn tình trạng hôn nhân",
            "options": [
              { "id": "opt-s", "label": "Độc thân", "value": "Single" },
              { "id": "opt-m", "label": "Đã kết hôn", "value": "Married" },
              {
                "id": "opt-r",
                "label": "Không muốn tiết lộ",
                "value": "Rather not mention"
              }
            ]
          }
        }
      }
    },
    "persNationality": {
      "kind": "system",
      "visible": true,
      "formBinding": "nationality",
      "ui": {
        "variant": "select",
        "label": "Nationality",
        "placeholder": "Select nationality",
        "options": [
          { "id": "vn", "label": "Vietnam (VN)", "value": "VN" },
          { "id": "us", "label": "United States (US)", "value": "US" },
          { "id": "sg", "label": "Singapore (SG)", "value": "SG" }
        ],
        "translations": {
          "vi-VN": {
            "label": "Quốc tịch",
            "placeholder": "Chọn quốc tịch",
            "options": [
              { "id": "vn", "label": "Việt Nam (VN)", "value": "VN" },
              { "id": "us", "label": "Hoa Kỳ (US)", "value": "US" },
              { "id": "sg", "label": "Singapore (SG)", "value": "SG" }
            ]
          }
        }
      }
    },
    "persNationalId": {
      "kind": "system",
      "visible": true,
      "formBinding": "nationalIdNumber",
      "ui": {
        "variant": "input",
        "label": "National ID Number",
        "placeholder": "National ID",
        "translations": {
          "vi-VN": {
            "label": "Số định danh quốc gia",
            "placeholder": "CCCD/CMND"
          }
        }
      }
    },
    "persIssuedDate": {
      "kind": "system",
      "visible": true,
      "formBinding": "issuedDate",
      "ui": {
        "variant": "date-picker",
        "label": "Issue Date",
        "placeholder": "Select issue date",
        "translations": {
          "vi-VN": {
            "label": "Ngày cấp",
            "placeholder": "Chọn ngày cấp"
          }
        }
      }
    },
    "persExpiryDate": {
      "kind": "system",
      "visible": true,
      "formBinding": "expiryDate",
      "ui": {
        "variant": "date-picker",
        "label": "Expiry Date",
        "placeholder": "Select expiry date",
        "translations": {
          "vi-VN": {
            "label": "Ngày hết hạn",
            "placeholder": "Chọn ngày hết hạn"
          }
        }
      }
    },
    "persEthnicity": {
      "kind": "system",
      "visible": true,
      "formBinding": "ethnicity",
      "ui": {
        "variant": "input",
        "label": "Ethnicity",
        "placeholder": "Ethnicity",
        "translations": {
          "vi-VN": {
            "label": "Dân tộc",
            "placeholder": "Dân tộc"
          }
        }
      }
    },
    "persIssueBy": {
      "kind": "system",
      "visible": true,
      "formBinding": "issueBy",
      "ui": {
        "variant": "input",
        "label": "Issue By",
        "placeholder": "Issued by",
        "translations": {
          "vi-VN": {
            "label": "Nơi cấp",
            "placeholder": "Nơi cấp"
          }
        }
      }
    },
    "persSocialInsurance": {
      "kind": "system",
      "visible": true,
      "formBinding": "socialInsurance",
      "ui": {
        "variant": "input",
        "label": "Social Insurance",
        "placeholder": "Social insurance number",
        "translations": {
          "vi-VN": {
            "label": "Số bảo hiểm xã hội",
            "placeholder": "Số bảo hiểm xã hội"
          }
        }
      }
    }
  }
}
