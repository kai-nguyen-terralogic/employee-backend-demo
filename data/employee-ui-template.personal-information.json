{
  "$comment": "Personal form aligned with fe-sub-app v2-form-config personalInformationDocument; formKey personal-information.",
  "templateId": "personal-information-default",
  "moduleKey": "employee-management",
  "formKey": "personal-information",
  "name": "Personal information",
  "version": 1,
  "status": "ACTIVE",
  "sourceSchemaVersion": "employee_schema_v2_4",
  "updatedAt": "2026-03-24T12:30:00.000Z",
  "layoutConstraints": { "maxFieldsPerRow": 2 },
  "sections": [
    {
      "key": "personal",
      "title": "Personal information",
      "rows": [
        { "key": "rowPhoneEmail", "fields": ["persPersonalPhone", "persPersonalEmail"] },
        { "key": "rowMaritalNationality", "fields": ["persMaritalStatus", "persNationality"] },
        { "key": "rowIdDates", "fields": ["persNationalId", "persEthnicity"] },
        { "key": "rowDates", "fields": ["persIssuedDate", "persExpiryDate"] },
        { "key": "rowIssueSocial", "fields": ["persIssueBy", "persSocialInsurance"] }
      ]
    }
  ],
  "fields": {
    "persPersonalPhone": {
      "kind": "system",
      "visible": true,
      "formBinding": "personalNumber",
      "ui": {
        "variant": "phone",
        "label": "Personal Number",
        "placeholder": "Enter personal phone number"
      }
    },
    "persPersonalEmail": {
      "kind": "system",
      "visible": true,
      "formBinding": "personalEmail",
      "ui": {
        "variant": "input",
        "type": "email",
        "label": "Personal Email",
        "placeholder": "e.g. personal@example.com"
      }
    },
    "persMaritalStatus": {
      "kind": "system",
      "visible": true,
      "formBinding": "maritalStatus",
      "ui": {
        "variant": "select",
        "label": "Marital Status",
        "placeholder": "Select marital status",
        "options": [
          { "id": "opt-s", "label": "Single", "value": "Single" },
          { "id": "opt-m", "label": "Married", "value": "Married" },
          { "id": "opt-r", "label": "Rather not mention", "value": "Rather not mention" }
        ]
      }
    },
    "persNationality": {
      "kind": "system",
      "visible": true,
      "formBinding": "nationality",
      "ui": {
        "variant": "select",
        "label": "Nationality",
        "placeholder": "Select nationality",
        "options": [
          { "id": "vn", "label": "Vietnam (VN)", "value": "VN" },
          { "id": "us", "label": "United States (US)", "value": "US" },
          { "id": "sg", "label": "Singapore (SG)", "value": "SG" }
        ]
      }
    },
    "persNationalId": {
      "kind": "system",
      "visible": true,
      "formBinding": "nationalIdNumber",
      "ui": {
        "variant": "input",
        "label": "National ID Number",
        "placeholder": "National ID"
      }
    },
    "persIssuedDate": {
      "kind": "system",
      "visible": true,
      "formBinding": "issuedDate",
      "ui": {
        "variant": "date-picker",
        "label": "Issue Date",
        "placeholder": "Select issue date",
        "dateFormat": "DMY"
      }
    },
    "persExpiryDate": {
      "kind": "system",
      "visible": true,
      "formBinding": "expiryDate",
      "ui": {
        "variant": "date-picker",
        "label": "Expiry Date",
        "placeholder": "Select expiry date",
        "dateFormat": "DMY"
      }
    },
    "persEthnicity": {
      "kind": "system",
      "visible": true,
      "formBinding": "ethnicity",
      "ui": {
        "variant": "input",
        "label": "Ethnicity",
        "placeholder": "Ethnicity"
      }
    },
    "persIssueBy": {
      "kind": "system",
      "visible": true,
      "formBinding": "issueBy",
      "ui": {
        "variant": "input",
        "label": "Issue By",
        "placeholder": "Issued by"
      }
    },
    "persSocialInsurance": {
      "kind": "system",
      "visible": true,
      "formBinding": "socialInsurance",
      "ui": {
        "variant": "input",
        "label": "Social Insurance",
        "placeholder": "Social insurance number"
      }
    }
  }
}
