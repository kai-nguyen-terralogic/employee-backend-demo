{
  "$comment": "Example EmployeeUiTemplate — align formBinding with fe-sub-app-employee-directory v2-form-config.ts (employee-information). Storage key: (tenant_id, formKey).",
  "templateId": "employee-information-default",
  "moduleKey": "employee-management",
  "formKey": "employee-information",
  "name": "Employee information",
  "version": 1,
  "status": "ACTIVE",
  "sourceSchemaVersion": "employee_schema_v2_4",
  "updatedAt": "2026-03-22T12:00:00.000Z",
  "layoutConstraints": { "maxFieldsPerRow": 2 },
  "sections": [
    {
      "key": "identity",
      "title": "Identity",
      "rows": [
        { "key": "rowNameSingle", "fields": ["sysFirstName"] },
        { "key": "rowNameSplit", "fields": ["sysMiddleName", "sysLastName"] },
        { "key": "rowIdDob", "fields": ["sysEmployeeId", "sysDob"] },
        { "key": "rowGender", "fields": ["sysGender"] },
        { "key": "rowEmail", "fields": ["sysWorkEmail"] },
        { "key": "rowPhones", "fields": ["sysWorkNumber", "sysUan"] },
        { "key": "rowCustom", "fields": ["cfShirtSize"] }
      ]
    }
  ],
  "fields": {
    "sysFirstName": {
      "kind": "system",
      "visible": true,
      "formBinding": "firstName",
      "ui": {
        "variant": "input",
        "label": "First Name",
        "placeholder": "e.g. John",
        "required": true,
        "translations": {
          "vi-VN": {
            "label": "Tên",
            "placeholder": "Ví dụ: John"
          }
        }
      }
    },
    "sysMiddleName": {
      "kind": "system",
      "visible": true,
      "formBinding": "middleName",
      "ui": {
        "variant": "input",
        "label": "Middle Name",
        "placeholder": "e.g. John",
        "translations": {
          "vi-VN": {
            "label": "Tên đệm",
            "placeholder": "Ví dụ: John"
          }
        }
      }
    },
    "sysLastName": {
      "kind": "system",
      "visible": true,
      "formBinding": "lastName",
      "ui": {
        "variant": "input",
        "label": "Last Name",
        "placeholder": "e.g. Doe",
        "required": true,
        "translations": {
          "vi-VN": {
            "label": "Họ",
            "placeholder": "Ví dụ: Doe"
          }
        }
      }
    },
    "sysEmployeeId": {
      "kind": "system",
      "visible": true,
      "formBinding": "employeeId",
      "disabled": true,
      "ui": {
        "variant": "input",
        "label": "Employee ID",
        "placeholder": "e.g. 123456",
        "required": true,
        "translations": {
          "vi-VN": {
            "label": "Mã nhân viên",
            "placeholder": "Ví dụ: 123456"
          }
        }
      }
    },
    "sysDob": {
      "kind": "system",
      "visible": true,
      "formBinding": "dob",
      "ui": {
        "variant": "date-picker",
        "label": "Date of birth",
        "placeholder": "Select date",
        "translations": {
          "vi-VN": {
            "label": "Ngày sinh",
            "placeholder": "Chọn ngày"
          }
        }
      }
    },
    "sysGender": {
      "kind": "system",
      "visible": true,
      "formBinding": "gender",
      "ui": {
        "variant": "radio-group",
        "label": "Gender",
        "orientation": "horizontal",
        "required": true,
        "options": [
          { "id": "opt-m", "label": "Male", "value": "MALE" },
          { "id": "opt-f", "label": "Female", "value": "FEMALE" },
          { "id": "opt-o", "label": "Other", "value": "OTHER" }
        ],
        "translations": {
          "vi-VN": {
            "label": "Giới tính",
            "options": [
              { "id": "opt-m", "label": "Nam", "value": "MALE" },
              { "id": "opt-f", "label": "Nữ", "value": "FEMALE" },
              { "id": "opt-o", "label": "Khác", "value": "OTHER" }
            ]
          }
        }
      }
    },
    "sysWorkEmail": {
      "kind": "system",
      "visible": true,
      "formBinding": "workEmail",
      "disabled": true,
      "ui": {
        "variant": "input",
        "type": "email",
        "label": "Work Email",
        "placeholder": "e.g. employee@company.com",
        "required": true,
        "translations": {
          "vi-VN": {
            "label": "Email công việc",
            "placeholder": "Ví dụ: nhanvien@congty.com"
          }
        }
      }
    },
    "sysWorkNumber": {
      "kind": "system",
      "visible": true,
      "formBinding": "workNumber",
      "ui": {
        "variant": "phone",
        "label": "Work Number",
        "placeholder": "Enter work phone number",
        "translations": {
          "vi-VN": {
            "label": "Số điện thoại công việc",
            "placeholder": "Nhập số điện thoại công việc"
          }
        }
      }
    },
    "sysUan": {
      "kind": "system",
      "visible": true,
      "formBinding": "uanNumber",
      "ui": {
        "variant": "input",
        "label": "UAN / National ID / SSN",
        "placeholder": "UAN (India), National ID (VN), or SSN (USA)",
        "translations": {
          "vi-VN": {
            "label": "Mã UAN / CCCD / SSN",
            "placeholder": "UAN (Ấn Độ), CCCD (VN) hoặc SSN (Mỹ)"
          }
        }
      }
    },
    "cfShirtSize": {
      "kind": "custom",
      "visible": true,
      "fieldId": "cfShirtSize",
      "formBinding": "cfShirtSize",
      "valueType": "string",
      "ui": {
        "variant": "select",
        "label": "T-shirt size",
        "placeholder": "Select size",
        "required": false,
        "options": [
          { "id": "s", "label": "S", "value": "S" },
          { "id": "m", "label": "M", "value": "M" },
          { "id": "l", "label": "L", "value": "L" }
        ],
        "translations": {
          "vi-VN": {
            "label": "Cỡ áo thun",
            "placeholder": "Chọn cỡ"
          }
        }
      }
    }
  }
}
